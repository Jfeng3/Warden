# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# LLM Providers
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Telegram (optional — omit to disable Telegram integration)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# WordPress (optional — SSH connection for wp-cli, format: user@host or user@host/path)
WP_SSH=user@ssh.wp.com

# Google Search Console (optional — inline service account JSON)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
