# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# LLM Providers
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Telegram (optional — omit to disable Telegram integration)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# WordPress (optional — SSH connection for wp-cli, format: user@host or user@host/path)
WP_SSH=user@ssh.wp.com

# Twitter/X (optional — OAuth 1.0a keys for posting tweets)
TWITTER_CONSUMER_KEY=your-consumer-key
TWITTER_CONSUMER_SECRET=your-consumer-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret

# Ahrefs (optional — API key for keyword research, get from https://app.ahrefs.com/user/api)
AHREF_API_KEY=your-ahrefs-api-key

# Google Search Console (optional — inline service account JSON)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
